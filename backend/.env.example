# =============================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to Git
# =============================================

PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/developershub
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/developershub

# JWT Secret - generate a strong random string:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_64_CHARS

JWT_EXPIRE=7d

NODE_ENV=production

# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-project.vercel.app

# =============================================
# Admin account seeding (used by: npm run seed)
# =============================================
ADMIN_NAME=Platform Admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
